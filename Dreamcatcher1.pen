            },
            {
              "type": "text",
              "id": "stCaQ",
              "x": 36,
              "y": 32,
              "name": "design-question",
              "fill": "#FFFFFF26",
              "textGrowth": "fixed-width",
              "width": 540,
              "content": "Can notifications be just text? No pills, no backgrounds, no icons —\njust words that appear briefly in a fixed position and fade.",
              "fontFamily": "Inconsolata",
              "fontSize": 10,
              "fontWeight": "normal"
            },
            {
              "type": "note",
              "id": "cRY5a",
              "x": 439.0602257692917,
              "y": 74.30923512243498,
              "width": 250,
              "height": 219,
              "content": "OK again you did a really nice job of keeping this component hyper-minimal. I really happen to like that we're showing only text for the toast messaging that denotes system status so I think this is a huge win. I really like that it appears as text only, mapped to the left-hand bottom corner of the page, and that after a finite period of time that text actually fades away. I think this is quite elegant and definitely would like to pursue including this within the system. "
            }
          ]
        },
