                      ]
                    }
                  ]
                },
                {
                  "type": "text",
                  "id": "FUBtK",
                  "name": "msg2text",
                  "fill": "#A8A8A8",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "That maps well to how reasoning actually works. A tree structure where you can fork, backtrack, and compare branches. The hard part is keeping spatial orientation intuitive as the graph grows beyond a single viewport.",
                  "lineHeight": 1.6,
                  "fontFamily": "Inconsolata",
                  "fontSize": 13
                }
              ]
            },
            {
              "type": "rectangle",
              "id": "WGqKZ",
              "name": "div3",
              "fill": "#1A1816",
              "width": "fill_container",
              "height": 1
            },
            {
              "type": "frame",
              "id": "Dl65r",
              "name": "m3",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 6,
