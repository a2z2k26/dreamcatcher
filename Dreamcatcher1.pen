                      "name": "triggerDesc",
                      "fill": "#404040",
                      "textGrowth": "fixed-width",
                      "width": 400,
                      "content": "Top: reply (corner-up-left)\nUpper-right: branch (git-branch)\nLower-right: learn (book-open)\nBottom: inspect (eye)\nLower-left: memory (bookmark)\nUpper-left: clip (scissors)\nTooltip pill on hover: E[3] bg, Inconsolata 8px",
                      "lineHeight": 1.8,
                      "fontFamily": "Inconsolata",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
