                },
                {
                  "type": "frame",
                  "id": "SSrgy",
                  "name": "Content Area",
                  "width": "fill_container",
                  "height": "fill_container",
                  "layout": "vertical",
                  "gap": 14,
                  "padding": [
                    14,
                    16,
                    0,
                    16
                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "dFmMw",
                      "name": "Content Paragraph 1",
                      "fill": "#A8A8A8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "RESTful patterns organize API endpoints around resources rather than actions. Instead of /getUser or /createOrder, you structure routes as /users and /orders, using HTTP methods (GET, POST, PUT, DELETE) to express intent.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inconsolata",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "Rydne",
                      "name": "Content Paragraph 2",
                      "fill": "#A8A8A8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "This matters here because your current architecture uses RPC-style endpoints. Migrating to REST would standardize the interface, make it self-documenting, and simplify client-side data fetching with predictable URL patterns.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inconsolata",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "DhAma",
                      "name": "Content Paragraph 3",
                      "fill": "#707070",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Key principles: statelessness (each request carries full context), uniform interface (consistent resource naming), and layered architecture (intermediary caches and proxies).",
                      "lineHeight": 1.6,
                      "fontFamily": "Inconsolata",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "hQVeR",
                  "name": "Follow-up Input",
                  "width": "fill_container",
                  "stroke": {
                    "thickness": {
                      "top": 1
                    },
                    "fill": "#252320"
                  },
                  "padding": [
                    12,
                    16
                  ],
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "text",
                      "id": "sWOsV",
                      "name": "Input Placeholder",
                      "fill": "#404040",
                      "content": "Ask a follow-up...",
                      "fontFamily": "Inconsolata",
                      "fontSize": 12,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
