                      "fontFamily": "Inconsolata",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "S8MUT",
                      "name": "r2",
                      "fill": "#404040",
                      "textGrowth": "fixed-width",
                      "width": 380,
                      "content": "Tier 0 (Common): Clean sphere, dim core T.dim #404040\nTier 1 (Uncommon): +1 orbital arc, core T.ghost #606060\nTier 2 (Rare): +arc +particles, core T.subtle #808080\nTier 3 (Epic): +breathing aura, core T.tertiary #A8A8A8\nTier 4 (Artifact): Brightest grey T.secondary #C8C8C8",
                      "lineHeight": 1.8,
                      "fontFamily": "Inconsolata",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "5xztU",
                      "name": "p1",
                      "fill": "#606060",
                      "content": "PROGRESSION RULES",
                      "fontFamily": "Inconsolata",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "GO2I5",
                      "name": "p2",
                      "fill": "#404040",
                      "textGrowth": "fixed-width",
                      "width": 380,
                      "content": "Warmth is NEVER applied. Grey luminance only.\nCore dot brightness earned through tier.\nOrbital arcs accumulate, never replace.\nSize grows with tier (48 → 64px).\nAccent color is RED #DD0000 — never peach.\nClassification: f(depth, branches, stars, saves)",
                      "lineHeight": 1.8,
                      "fontFamily": "Inconsolata",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "id": "arXMl",
              "name": "Rarity Annotation",
              "fill": "#404040",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "CLASSIFICATION FORMULA: tier = floor(min(4, log2(1 + depth*0.3 + branches*0.5 + stars*1.0 + saves*0.8))). Tier transitions animate over 600ms — orbital arcs fade in sequentially (200ms stagger). Particle count: Tier 2 = 3, Tier 3 = 3, Tier 4 = 3 (brighter). Node body size: 48 + tier*4 px.",
              "lineHeight": 1.8,
              "fontFamily": "Inconsolata",
              "fontSize": 10,
              "fontWeight": "normal",
              "letterSpacing": 0.3
            }
          ]
        },
