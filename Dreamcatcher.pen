                              "id": "P9lKC",
                              "name": "msg2txt",
                              "fill": "#A09A90",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Design tokens cascade through three layers: global primitives, semantic aliases, and component-level overrides. Each layer narrows scope while inheriting from above.",
                              "fontFamily": "Inconsolata",
                              "fontSize": 12,
                              "fontWeight": "normal"
                            },
                            {
