                      "children": [
                        {
                          "type": "text",
                          "id": "8arxm",
                          "name": "Key Insight Header",
                          "fill": "#DD0000",
                          "content": "KEY INSIGHT",
                          "fontFamily": "Inconsolata",
                          "fontSize": 9,
                          "fontWeight": "600",
                          "letterSpacing": 1.5
                        },
                        {
                          "type": "frame",
                          "id": "dZC7K",
                          "name": "Key Insight Card",
                          "width": "fill_container",
                          "fill": "#13120F",
                          "cornerRadius": 4,
                          "stroke": {
                            "thickness": 0.5,
                            "fill": "#252320"
                          },
                          "layout": "vertical",
                          "gap": 8,
                          "padding": [
                            14,
                            16
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "G4pmN",
                              "name": "Insight Body",
                              "fill": "#C8C8C8",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "LLMs hallucinate because they are probabilistic text generators, not knowledge databases. They predict the most likely next token based on patterns in training data, not by retrieving verified facts. When the model encounters gaps in its learned distribution, it fills them with statistically plausible but factually incorrect completions.",
                              "lineHeight": 1.6,
                              "fontFamily": "Inter",
                              "fontSize": 13,
                              "fontWeight": "normal"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "Geq54",
                          "name": "How It Works Header",
                          "fill": "#808080",
                          "content": "HOW IT WORKS",
                          "fontFamily": "Inconsolata",
                          "fontSize": 9,
                          "fontWeight": "600",
                          "letterSpacing": 1.5
                        },
                        {
                          "type": "text",
                          "id": "M3sQu",
                          "name": "How It Works Body",
                          "fill": "#A8A8A8",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The transformer architecture processes input through attention layers that weight token relationships. At each generation step, the model samples from a probability distribution over its vocabulary. Temperature and top-p parameters control the sampling randomness.",
                          "lineHeight": 1.6,
                          "fontFamily": "Inter",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "KXtjP",
                          "name": "Code Snippet Block",
                          "width": "fill_container",
                          "fill": "#13120F",
                          "cornerRadius": 4,
                          "stroke": {
                            "thickness": 0.5,
                            "fill": "#1A1916"
                          },
                          "layout": "vertical",
                          "gap": 6,
                          "padding": [
                            12,
                            16
                          ],
                          "children": [
                            {
                              "type": "text",
                              "id": "m1xk8",
                              "name": "Code Language Label",
                              "fill": "#505050",
                              "content": "PSEUDOCODE",
                              "fontFamily": "Inconsolata",
                              "fontSize": 8,
                              "fontWeight": "600",
                              "letterSpacing": 1
                            },
                            {
                              "type": "text",
                              "id": "ZJlQt",
                              "name": "code-line-1",
                              "fill": "#808080",
                              "content": "logits = model.forward(input_tokens)",
                              "lineHeight": 1.5,
                              "fontFamily": "Inconsolata",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "KLQ9a",
                              "name": "code-line-2",
                              "fill": "#808080",
                              "content": "probs = softmax(logits / temperature)",
                              "lineHeight": 1.5,
                              "fontFamily": "Inconsolata",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "IK1sp",
                              "name": "code-line-3",
                              "fill": "#808080",
                              "content": "next_token = sample(probs, top_p=0.9)",
                              "lineHeight": 1.5,
                              "fontFamily": "Inconsolata",
                              "fontSize": 11,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "cbYv1",
                              "name": "code-line-4",
                              "fill": "#606060",
                              "content": "# No ground-truth check happens here",
                              "lineHeight": 1.5,
                              "fontFamily": "Inconsolata",
                              "fontSize": 11,
                              "fontWeight": "normal",
                              "fontStyle": "italic"
                            }
                          ]
