              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "MATERIAL LAYER STACK (bottom → top): dropShadow (radial #000 gradient, opacity 0.5) → body (radial gradient E[6]→E[2], stroke) → rimLight (#FFFFFF08, 0.5px, opacity 0.6) → specular (white radial, opacity 0.08–0.15) → coreDot (grey radial gradient, 12px). State additions layer ABOVE this stack. Selection rings below body, breathing rings outside rimLight.",
              "lineHeight": 1.8,
              "fontFamily": "Inconsolata",
              "fontSize": 10,
              "fontWeight": "normal",
              "letterSpacing": 0.3
            }
