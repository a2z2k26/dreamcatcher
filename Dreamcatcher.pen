                    },
                    {
                      "type": "text",
                      "id": "yffYR",
                      "name": "r2",
                      "fill": "#404040",
                      "textGrowth": "fixed-width",
                      "width": 400,
                      "content": "Stage 1 (0-100ms): Ring appears at r+12, 0.8px, faint\nStage 2 (100-250ms): Ring contracts toward r+6\nStage 3 (250-400ms): Ring solidifies at r+6, 1.5px\n  Breathing ring fades in at r+12, halo at 8%\nStage 4 (400ms+): Standard 3-layer selection\n  Inspector panel slides in from right",
                      "lineHeight": 1.8,
                      "fontFamily": "Inconsolata",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "DUJHk",
                      "name": "c1",
                      "fill": "#606060",
                      "content": "TREATMENT",
                      "fontFamily": "Inconsolata",
                      "fontSize": 11,
                      "fontWeight": "700",
                      "letterSpacing": 2
                    },
                    {
                      "type": "text",
                      "id": "6pawt",
                      "name": "c2",
                      "fill": "#404040",
                      "textGrowth": "fixed-width",
                      "width": 400,
                      "content": "Ring stroke: ACCENT #DD0000 at 0.7 opacity\nBreathing ring: ACCENT #DD0000 at 0.3 opacity\nHalo: radial gradient ACCENT 8% → transparent\nCore dot: brightens to T.secondary #A0A0A0\nACCENT color throughout. No reticle. No brackets.\nTotal animation: 400ms ease-out",
                      "lineHeight": 1.8,
                      "fontFamily": "Inconsolata",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "text",
              "id": "LjVWY",
              "name": "Easing Annotation",
              "fill": "#404040",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "EASING: All transitions use ease-out (cubic-bezier(0, 0, 0.2, 1)). Ring radius interpolation: r+12 → r+6 over 250ms. Opacity transitions: linear. Breathing ring: sinusoidal oscillation, period 2s, amplitude 0.1–0.2 opacity. Inspector panel: slide-in from right 300ms, overlaps animation tail.",
              "lineHeight": 1.8,
              "fontFamily": "Inconsolata",
              "fontSize": 10,
              "fontWeight": "normal",
              "letterSpacing": 0.3
            }
          ]
