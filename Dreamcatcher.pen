                              "type": "frame",
                              "id": "dz4px",
                              "name": "User Bubble 2",
                              "fill": "#1E1C19",
                              "cornerRadius": [
                                8,
                                8,
                                2,
                                8
                              ],
                              "stroke": {
                                "thickness": 0.5,
                                "fill": "#252320"
                              },
                              "layout": "vertical",
                              "padding": [
                                10,
                                14
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "tXPoj",
                                  "name": "userBubble2Txt",
                                  "fill": "#C8C8C8",
                                  "textGrowth": "fixed-width",
                                  "width": 300,
                                  "content": "Can RAG completely solve this problem?",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "AKn4P",
                          "name": "AI Message 2",
                          "width": "fill_container",
                          "children": [
                            {
                              "type": "frame",
                              "id": "NrPwc",
                              "name": "AI Bubble 2",
                              "fill": "#13120F",
                              "cornerRadius": [
                                8,
                                8,
                                8,
                                2
                              ],
                              "stroke": {
                                "thickness": 0.5,
                                "fill": "#1A1916"
                              },
                              "layout": "vertical",
                              "gap": 8,
                              "padding": [
                                10,
                                14
                              ],
                              "children": [
                                {
                                  "type": "text",
                                  "id": "3pZBy",
                                  "name": "aiBubble2Txt",
                                  "fill": "#A8A8A8",
                                  "textGrowth": "fixed-width",
                                  "width": 420,
                                  "content": "RAG significantly reduces hallucination by grounding responses in retrieved documents, but it cannot eliminate it entirely. The model can still misinterpret retrieved context, or hallucinate in the gaps between retrieved passages.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "Inter",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
